{
    "name": "spend-watcher-backend",
    "version": "0.0.2",
    "type": "module",
    "description": "",
    "main": "ts-node src/index.ts",
    "scripts": {
        "start": "npx tsx src/index.ts",
        "dev": "tsx watch src/index.ts",
        "test": "echo \"Error: no test specified\" && exit 1",
        "lint": "npx eslint --ext .ts",
        "lint:fix": "npx eslint --fix --ext .ts",
        "format": "npx prettier --write"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/CameronKnaus/spend-watcher-backend.git"
    },
    "author": "Cameron Knaus",
    "license": "ISC",
    "bugs": {
        "url": "https://github.com/CameronKnaus/spend-watcher-backend/issues"
    },
    "homepage": "https://github.com/CameronKnaus/spend-watcher-backend#readme",
    "dependencies": {
        "bcryptjs": "^2.4.3",
        "cookie-parser": "^1.4.6",
        "cors": "^2.8.5",
        "date-fns": "^3.6.0",
        "dotenv": "^16.4.5",
        "express": "^4.19.2",
        "express-jwt": "^8.4.1",
        "helmet": "^4.1.1",
        "jsonwebtoken": "^8.5.1",
        "jwks-rsa": "^1.12.3",
        "morgan": "^1.10.0",
        "mysql": "^2.18.1",
        "uuid": "^9.0.1",
        "zod": "^3.23.4"
    },
    "devDependencies": {
        "@eslint/js": "^9.7.0",
        "@types/bcryptjs": "^2.4.6",
        "@types/cookie-parser": "^1.4.7",
        "@types/express": "^4.17.21",
        "@types/jsonwebtoken": "^9.0.6",
        "@types/mysql": "^2.15.26",
        "@types/node": "^20.12.7",
        "@types/uuid": "^9.0.8",
        "@typescript-eslint/eslint-plugin": "^7.16.1",
        "eslint": "^8.2.0",
        "eslint-config-airbnb-base": "^15.0.0",
        "eslint-plugin-import": "^2.29.1",
        "globals": "^15.8.0",
        "prettier": "^3.2.5",
        "ts-node": "^10.9.2",
        "tsx": "^4.7.1",
        "typescript": "^5.4.3"
    },
    "eslintConfig": {
        "extends": "airbnb-base",
        "env": {
            "es6": true,
            "browser": true
        },
        "parserOptions": {
            "ecmaVersion": "latest"
        },
        "rules": {
            "brace-style": [
                "error",
                "1tbs",
                {
                    "allowSingleLine": true
                }
            ],
            "comma-dangle": [
                "error",
                "never"
            ],
            "no-unused-vars": [
                "warn"
            ],
            "no-var": [
                "off"
            ],
            "one-var": [
                "off"
            ],
            "indent": [
                "error",
                4
            ],
            "consistent-return": [
                "off"
            ],
            "no-param-reassign": [
                "off"
            ],
            "prefer-promise-reject-errors": [
                "off"
            ],
            "camelcase": "off",
            "max-len": "off",
            "no-plusplus": "off",
            "no-console": "off",
            "no-continue": "off"
        }
    }
}
