{
    "extends": "../tsconfig.base.json",
    "compilerOptions": {
        "target": "ESNext",
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "rootDir": "src",
        "baseUrl": "./",
        "paths": {
            "@routes/*": ["src/routes/*"],
            "@lib/*": ["src/lib/*"],
            "@utils/*": ["src/utils/*"],
            "@type/*": ["src/type/*"]
        },
        "outDir": "dist",
        "noUnusedLocals": true,
        "noUnusedParameters": true
    },
    "include": ["./", "./custom.d.ts", "src/index.ts"]
}
