{
  "name": "spend-watcher",
  "description": "This project is for personal spending tracking. It is a monolith encompassing a react frontend and node backend.",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "start": "pnpm -r --parallel run dev",
    "dev": "pnpm -r --parallel run dev",
    "lint": "pnpm -r run lint",
    "lint:fix": "pnpm -r run lint:fix",
    "format": "pnpm -r run format",
    "test": "pnpm --filter @spend-watcher/ui run test"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.1",
    "prettier": "^3.8.3",
    "typescript": "^5.9.3"
  }
}
